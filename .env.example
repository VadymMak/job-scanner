# Скопируй в .env и заполни реальными значениями

# --- База данных ---
DATABASE_URL=postgresql+psycopg://scanner:scanner@127.0.0.1:5432/job_scanner

# --- Telegram (опционально) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- LLM (опционально) ---
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- Приложение ---
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=900
